{
    "name": "sap-laravel-12",
    "version": "1.0.0",
    "description": "SAP-like business management system built with Laravel 12",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint resources/js --ext .js,.vue",
        "lint:fix": "eslint resources/js --ext .js,.vue --fix",
        "format": "prettier --write resources/js/**/*.{js,vue}",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "coverage": "vitest --coverage"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.10",
        "@vitejs/plugin-vue": "^5.0.4",
        "autoprefixer": "^10.4.17",
        "axios": "^1.6.7",
        "eslint": "^8.56.0",
        "eslint-plugin-vue": "^9.20.1",
        "laravel-vite-plugin": "^1.0.2",
        "postcss": "^8.4.35",
        "prettier": "^3.2.5",
        "tailwindcss": "^3.4.1",
        "vite": "^5.1.4",
        "vitest": "^1.3.1",
        "vue": "^3.4.21"
    },
    "dependencies": {
        "@headlessui/vue": "^1.7.17",
        "@heroicons/vue": "^2.1.1",
        "@inertiajs/vue3": "^1.0.14",
        "chart.js": "^4.4.1",
        "date-fns": "^3.3.1",
        "lodash": "^4.17.21",
        "vue-chartjs": "^5.3.0",
        "vue-router": "^4.2.5"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ]
}
